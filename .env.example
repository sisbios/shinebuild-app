# ============================================================
# NEXT_PUBLIC_* — safe for browser bundle
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=   # reCAPTCHA v3 site key
NEXT_PUBLIC_APP_URL=https://shinebuild.sisbios.cloud

# ============================================================
# Server-only — NEVER expose to browser
# ============================================================
FIREBASE_PROJECT_ID=shinebuild-prod
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=   # Keep \n escaped, wrap in quotes in .env

# Session cookie signing (next-firebase-auth-edge)
COOKIE_SECRET_CURRENT=   # 32+ random chars
COOKIE_SECRET_PREVIOUS=  # rotation pair

# ============================================================
# Runtime
# ============================================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1
