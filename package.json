{
  "name": "shinebuild-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared",
    "packages/ui",
    "packages/firebase",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/ui && npm run build --workspace=packages/firebase && npm run build --workspace=apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "emulators": "firebase emulators:start",
    "emulators:test": "firebase emulators:exec \"npm run test:integration\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "next": "15.5.12"
  },
  "overrides": {
    "firebase-admin": "^13.0.0"
  }
}
